# NOTE: public/build is intentionally COMMITTED (tracked). The production
# server has no Node/Vite build step, so the dashboards' @vite assets
# (dashboard.css/js) must be pre-built locally and shipped via git.
# Run `npm run build` and commit public/build before every deploy that
# changed dashboard CSS/JS. (Dev-only artifacts below stay ignored.)
/public/fonts-manifest.dev.json
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
_ide_helper.php
Homestead.json
Homestead.yaml
Thumbs.db
/PDFs
upgrade_plan.md

# Scribe API docs. knuckleswtf/scribe is a require-dev dependency (absent in
# production: the deploy runs `composer install --no-dev`). config/scribe.php IS
# committed but starts with a guard that returns [] when Scribe is missing, so it
# is safe to load in production. The static docs SITE is generated to public/docs
# and IS committed (served at /docs, exactly like public/build). Only Scribe's
# regeneration intermediates/artifacts are ignored:
/.scribe
/public/vendor/scribe
/resources/views/scribe
/storage/app/private/scribe
