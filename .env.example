APP_NAME=Mazayada
APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Africa/Algiers
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mazayada
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb

# Cache, sessions, queues all go through Redis for production-grade performance.
# Fallback values let the app keep working locally if Redis is not yet running.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
CACHE_PREFIX=mazayada_cache

QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=90

FILESYSTEM_DISK=local

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=mazayada_database_

# Broadcasting / WebSockets (Laravel Reverb)
REVERB_APP_ID=170884
REVERB_APP_KEY=zht9kylgbhi8m05h4hgc
REVERB_APP_SECRET=njku8a2eqsxcmvmqunly
REVERB_HOST=127.0.0.1
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mail — registration OTP is email-only. Use SMTP for real delivery.
# port 587 = STARTTLS (leave MAIL_SCHEME empty); port 465 = set MAIL_SCHEME=smtps.
# Gmail: smtp.gmail.com / Resend: smtp.resend.com / Brevo: smtp-relay.brevo.com
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=
MAIL_FROM_ADDRESS="no-reply@mazayada.dz"
MAIL_FROM_NAME="${APP_NAME}"

# Throttle / security
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
BID_MAX_PER_MINUTE=10

# Payment gateway — driver selection: 'mock' | 'chargily' | 'cibweb'.
# 'mock' = in-process simulation (no network). Leave as mock for local/tests.
PAYMENTS_DRIVER=mock

# Legacy CIBWeb/SATIM (kept for compatibility; CIBWEB_MOCK only matters when
# PAYMENTS_DRIVER is unset).
CIBWEB_BASE_URL=https://test.satim.dz/payment/rest
CIBWEB_USERNAME=mazayada_test
CIBWEB_PASSWORD=test_password_placeholder
CIBWEB_MOCK=true

# Chargily Pay (EDAHABIA / CIB). To use the REAL hosted checkout in TEST mode:
# set PAYMENTS_DRIVER=chargily and paste your test_sk_... key below. The checkout
# page is real; no real money moves. To go LIVE, swap base_url to
# https://pay.chargily.net/api/v2 and use your live_sk_... key (no code change).
CHARGILY_BASE_URL=https://pay.chargily.net/test/api/v2
CHARGILY_SECRET_KEY=
CHARGILY_WEBHOOK_SECRET=
CHARGILY_PAYMENT_METHOD=cib

# KYC / Biometrics
KYC_LIVENESS_THRESHOLD=0.85
KYC_MATCH_THRESHOLD=0.80

# Document signing
ALIAS_SECRET=
QR_VERIFICATION_BASE_URL="${APP_URL}/verify"

# Generated documents (award / condition book / receipt / delivery report)
# Stored on a PRIVATE disk (storage/app/private/documents) — never public.
DOCUMENTS_DISK=documents
# HMAC key for the QR verification signature on generated PDFs (falls back to APP_KEY).
DOCUMENT_SIGNING_KEY=
